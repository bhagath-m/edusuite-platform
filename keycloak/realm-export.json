{
  "realm": "edusuite",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "roles": {
    "realm": [
      { "name": "PLATFORM_ADMIN", "description": "Internal super-admin, cross-tenant. Grant extremely sparingly." },
      { "name": "ADMIN", "description": "Institute admin/owner - tenant-scoped" },
      { "name": "STAFF", "description": "Front office / registrar staff - tenant-scoped" },
      { "name": "TEACHER", "description": "Teacher/faculty - tenant-scoped" },
      { "name": "STUDENT", "description": "Student - tenant-scoped" },
      { "name": "PARENT", "description": "Parent/guardian - tenant-scoped" }
    ]
  },
  "clientScopes": [
    {
      "name": "tenant",
      "description": "Adds the tenant_id claim (from the user's tenant_id attribute) to issued tokens",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "tenant_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "tenant_id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "tenant_id",
            "jsonType.label": "String"
          }
        },
        {
          "name": "preferred_username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "username",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "preferred_username",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "edusuite-app",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["http://localhost:5173/*", "http://localhost:8080/*"],
      "webOrigins": ["*"],
      "defaultClientScopes": ["openid", "profile", "email", "tenant"]
    }
  ],
  "users": [
    {
      "username": "admin@tenant-a.test",
      "firstName": "Admin",
      "lastName": "TenantA",
      "enabled": true,
      "email": "admin@tenant-a.test",
      "emailVerified": true,
      "requiredActions": [],
      "credentials": [
        { "type": "password", "value": "password123", "temporary": false }
      ],
      "realmRoles": ["ADMIN"],
      "attributes": {
        "tenant_id": ["00000000-0000-0000-0000-000000000001"]
      }
    },
    {
      "username": "admin@tenant-b.test",
      "firstName": "Admin",
      "lastName": "TenantB",
      "enabled": true,
      "email": "admin@tenant-b.test",
      "emailVerified": true,
      "requiredActions": [],
      "credentials": [
        { "type": "password", "value": "password123", "temporary": false }
      ],
      "realmRoles": ["ADMIN"],
      "attributes": {
        "tenant_id": ["00000000-0000-0000-0000-000000000002"]
      }
    }
  ]
}
